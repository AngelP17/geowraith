GEOWRAITH_API_PORT=8080
GEOWRAITH_MAX_IMAGE_BYTES=10485760
GEOWRAITH_OFFLINE=true
GEOWRAITH_ENABLE_SFM=false
GEOWRAITH_ENABLE_UNIVERSAL_FORMAT=true
GEOWRAITH_IMAGE_PREPROCESS_MODE=cover-224-jpeg
GEOWRAITH_IMAGE_EMBEDDING_BACKEND=auto
GEOWRAITH_REFERENCE_BACKEND=auto
GEOWRAITH_USE_UNIFIED_INDEX=true
GEOWRAITH_ENABLE_VERIFIER=false
GEOWRAITH_LLM_MODEL=qwen3.5:9b
GEOWRAITH_VERIFIER_TIMEOUT=30000
OLLAMA_ENDPOINT=http://localhost:11434
GEOWRAITH_ENABLE_BRIEF=false
GEOWRAITH_ENABLE_ANOMALY=false

# Optional: Mapillary OAuth access token for SfM reference retrieval
MAPILLARY_ACCESS_TOKEN=

# Optional: Unsplash API key for image search
# Get your key at https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=

# Optional: Pexels API key for image search
# Get your key at https://www.pexels.com/api/
PEXELS_API_KEY=

# Optional: Pixabay API key for image search
# Get your key at https://pixabay.com/api/docs/
PIXABAY_API_KEY=

# =============================================================================
# ULTRA ACCURACY MODE (v2.2+)
# =============================================================================
# Enable aggressive accuracy tuning for 10m median / 1km P95 targets
# This activates: IQR outlier rejection, weighted median centroid, 
# tighter clustering, and geographic constraints
GEOWRAITH_ULTRA_ACCURACY=true

# Cluster radius in meters (default: 30000 in Ultra Mode)
# Smaller = tighter clusters, more precise but may miss candidates
# Larger = looser clusters, better recall but less precision
# GEOWRAITH_CLUSTER_RADIUS_M=30000

# Minimum candidates required for a valid cluster (default: 4 in Ultra Mode)
# GEOWRAITH_MIN_CLUSTER_CANDIDATES=4

# Maximum candidates to use in cluster (default: 8 in Ultra Mode)
# GEOWRAITH_MAX_CLUSTER_CANDIDATES=8

# Number of top matches to consider for clustering (default: 32 in Ultra Mode)
# GEOWRAITH_CLUSTER_SEARCH_DEPTH=32

# Enable IQR-based outlier rejection (default: true)
# Disabling may improve speed at cost of P95 accuracy
# GEOWRAITH_OUTLIER_REJECTION=true

# =============================================================================
# DATASET CONFIGURATION
# =============================================================================
# Number of reference coordinates to generate (default: 500000)
# GEOWRAITH_COORDINATE_COUNT=500000

# ANN search tier configuration
# GEOWRAITH_ANN_TIER1_CANDIDATES=500
# GEOWRAITH_ANN_TIER2_CANDIDATES=200
# GEOWRAITH_ANN_TIER3_CANDIDATES=50

# DBSCAN clustering parameters
# GEOWRAITH_DBSCAN_EPSILON=50000
# GEOWRAITH_DBSCAN_MINPOINTS=3

# =============================================================================
# ANOMALY DETECTION API KEYS (v2.2+)
# =============================================================================
# Enable anomaly detection (fire, conflict, military activity near predictions)
# GEOWRAITH_ENABLE_ANOMALY=false

# NASA FIRMS API key for fire detection
# Get your free MAP_KEY at https://firms.modaps.eosdis.nasa.gov/api/map_key/
# Rate limit: 5000 transactions / 10 minutes
# Without this key, falls back to hardcoded fire-prone regions
# NASA_FIRMS_API_KEY=37ce30ac77c4fc15c96894d4fe545d43

# ACLED API credentials for conflict/event data
# Get access at https://acleddata.com/acled-datanexusbulk-data-portal/
# Without these credentials, falls back to hardcoded conflict zones
ACLED_API_KEY=
ACLED_EMAIL=
